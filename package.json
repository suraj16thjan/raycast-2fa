{
  "name": "2fa",
  "title": "2FA Codes",
  "description": "Generate 2FA TOTP codes using the 2fa CLI",
  "icon": "icon.png",
  "author": "suraj_lama",
  "categories": [
    "Security"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "list-codes",
      "title": "List 2FA Codes",
      "subtitle": "2FA",
      "description": "List all 2FA accounts and copy codes to clipboard",
      "mode": "view"
    },
    {
      "name": "add-account",
      "title": "Add 2FA Account",
      "subtitle": "2FA",
      "description": "Add a new 2FA account",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "~22.13.4",
    "@types/react": "^19.0.8",
    "eslint": "^9.39.3",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "ray build --skip-types -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
